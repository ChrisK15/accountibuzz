rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can only upload to their own submissions folder.
    // Any authenticated user can read submissions (for review/playback).
    match /users/{userId}/submissions/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
